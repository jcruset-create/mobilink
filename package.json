{
  "name": "sea-tarragona",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mobile": "tsc -b && vite build --mode mobile",
    "preview": "vite preview --host",
    "serve:prod": "vite preview --host --port 4173",
    "mobile:sync": "npm run build:mobile && cap sync",
    "mobile:android": "npm run build:mobile && cap sync android && cap open android",
    "mobile:ios": "npm run build:mobile && cap sync ios && cap open ios",
    "tecnicos:build": "vite build --config vite.tecnicos.config.ts && node -e \"require('fs').renameSync('dist-tecnicos/index-tecnicos.html','dist-tecnicos/index.html')\"",
    "tecnicos:sync": "npm run tecnicos:build && node scripts/sync-tecnicos.mjs",
    "tecnicos:android": "npm run tecnicos:sync && cap open android --project android-tecnicos",
    "backup": "node scripts/backup.cjs",
    "server": "tsx server/index.ts",
    "start": "tsx server/index.ts",
    "seed": "tsx server/seed.ts",
    "backup:postgres": "tsx server/backup-postgres.ts",
    "restore:postgres": "tsx server/restore-postgres.ts",
    "setup:buckets": "tsx scripts/setup-supabase-buckets.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.0",
    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@supabase/supabase-js": "^2.105.1",
    "@types/leaflet": "^1.9.21",
    "@types/pdfkit": "^0.17.6",
    "better-sqlite3": "^12.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.7.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.539.0",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.0",
    "openai": "^6.34.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.0",
    "pg": "^8.20.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-qr-code": "^2.0.21",
    "react-router-dom": "^7.15.0",
    "stripe": "^22.1.1",
    "tesseract.js": "^7.0.0",
    "tsx": "^4.21.0",
    "twilio": "^6.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "supabase": "^2.101.0",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
