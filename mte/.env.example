# ── Mobilink Telematics Engine (MTE) ─────────────────────────────
# Entorno: development | production
NODE_ENV=development
LOG_LEVEL=info

# Servidor TCP Teltonika
TCP_PORT=5027
TCP_HOST=0.0.0.0
# Milisegundos de inactividad antes de cerrar la sesión del dispositivo
TCP_IDLE_TIMEOUT_MS=600000
# Máximo de conexiones simultáneas
TCP_MAX_CONNECTIONS=5000

# API REST + WebSocket
HTTP_PORT=8080
# API key exigida en cabecera x-api-key para la API REST
API_KEY=change-me

# Supabase / PostgreSQL
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Esquema donde viven las tablas del MTE
SUPABASE_SCHEMA=public

# Validación de dispositivos
# strict  -> solo IMEIs registrados y autorizados en mte_devices
# permissive -> auto-registra IMEIs desconocidos como no autorizados (no persisten datos)
# open -> acepta cualquier IMEI (SOLO desarrollo/pruebas)
DEVICE_AUTH_MODE=strict

# Deduplicación (ventana en segundos para descartar posiciones duplicadas)
DEDUP_WINDOW_SECONDS=86400

# Geocercas: radio por defecto en metros para llegadas (asistencias/clientes/taller)
ARRIVAL_RADIUS_METERS=150
