# Fleet Integration Hub
FIH_PORT=8090

# PostgreSQL (Supabase: usar la connection string del pooler)
DATABASE_URL=postgresql://user:pass@host:5432/postgres?schema=public

# Clave para cifrado AES-256-GCM de credenciales de proveedores (obligatoria en producción)
FIH_ENCRYPTION_KEY=change-me-32-chars-min
