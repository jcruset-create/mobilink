# Render / server
NODE_ENV=production
PUBLIC_APP_URL=https://sea-tarragona.onrender.com
AGENDA_TIME_ZONE=Europe/Madrid

# PostgreSQL / Supabase database used by the Express backend
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# Supabase backend admin client
SUPABASE_URL=https://PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
SUPABASE_STORAGE_BUCKET=avatars
SUPABASE_ROADSIDE_BUCKET=roadside

# Supabase frontend client, required at Vite build time
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-anon-key

# App passwords / roles
ADMIN_TOKEN=
ADMIN_PASSWORD=replace-with-admin-password
SUPERVISOR_PASSWORD=replace-with-supervisor-password
SCREENS_PASSWORD=replace-with-screens-password
TV75_PASSWORD=replace-with-tv75-password
BACKUP_PASSWORD=replace-with-backup-password
ROADSIDE_OPERATOR_CODE=
APP_PASSWORD=

# OpenAI OCR / parsing
OPENAI_API_KEY=replace-with-openai-api-key

# WhatsApp / Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+34000000000
TWILIO_WHATSAPP_NUMBER=
TWILIO_CONTENT_SID=
TWILIO_ROADSIDE_CONTENT_SID=
TWILIO_JOB_FINISHED_CONTENT_SID=

# SEA Administración — envíos automáticos de recobros
# Plantillas de WhatsApp aprobadas en Twilio (Content Templates)
TWILIO_RECOBROS_CONTENT_SID=
TWILIO_RECOBROS_RESUMEN_SID=
# Hora a partir de la cual se procesan los envíos del día (HH:MM, hora de Madrid)
RECOBROS_NOTIFY_HOUR=08:00

# Email (informes de asistencia y recordatorios de recobro)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stripe / cobros
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
